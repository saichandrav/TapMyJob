%-------------------------
% Custom commands
\newcommand{\resumeItem}[2]{
  \item\small{
    \textbf{#1}{: #2 \vspace{-2pt}}
  }
}

\newcommand{\resumeItemBullet}[1]{
  \item\small{
    {#1 \vspace{-2pt}}
  }
}

\newcommand{\resumeSubheading}[4]{
  \vspace{-1pt}\item
    \begin{tabular*}{0.97\textwidth}[t]{l@{\extracolsep{\fill}}r}
      \textbf{#1} & #2 \\
      \textit{\small#3} & \textit{\small #4} \\
    \end{tabular*}\vspace{-5pt}
}

\newcommand{\resumeSubSubheading}[2]{
    \begin{tabular*}{0.97\textwidth}{l@{\extracolsep{\fill}}r}
      \textit{\small#1} & \textit{\small #2} \\
    \end{tabular*}\vspace{-5pt}
}

\newcommand{\resumeSubItem}[2]{\resumeItem{#1}{#2}\vspace{-4pt}}

\renewcommand{\labelitemii}{$\circ$}

\newcommand{\resumeSubHeadingListStart}{\begin{itemize}[leftmargin=*]}
\newcommand{\resumeSubHeadingListEnd}{\end{itemize}}
\newcommand{\resumeItemListStart}{\begin{itemize}}
\newcommand{\resumeItemListEnd}{\end{itemize}\vspace{-5pt}}

%-------------------------------------------
%%%%%%  CV STARTS HERE  %%%%%%%%%%%%%%%%%%%%%%%%%%%%

\begin{document}

%----------HEADING-----------------
\begin{center}
    \textbf{\Huge \scshape \BLOCK{ if name }\VAR{name}\BLOCK{ else }Professional Candidate\BLOCK{ endif }} \\ \vspace{1pt}
    \small
    \BLOCK{ if phone }\VAR{phone}\BLOCK{ endif }
    \BLOCK{ if phone and email } $|$ \BLOCK{ endif }
    \BLOCK{ if email }\href{mailto:\VAR{email}}{\VAR{email}}\BLOCK{ endif }
    \BLOCK{ if (phone or email) and linkedin } $|$ \BLOCK{ endif }
    \BLOCK{ if linkedin }\href{\VAR{linkedin}}{LinkedIn}\BLOCK{ endif }
    \BLOCK{ if (phone or email or linkedin) and github } $|$ \BLOCK{ endif }
    \BLOCK{ if github }\href{\VAR{github}}{GitHub}\BLOCK{ endif }
    \BLOCK{ if (phone or email or linkedin or github) and codechef } $|$ \BLOCK{ endif }
    \BLOCK{ if codechef }\href{\VAR{codechef}}{CodeChef}\BLOCK{ endif }
    \BLOCK{ if (phone or email or linkedin or github or codechef) and leetcode } $|$ \BLOCK{ endif }
    \BLOCK{ if leetcode }\href{\VAR{leetcode}}{LeetCode}\BLOCK{ endif }
\end{center}

%-----------PROFESSIONAL SUMMARY-----------------
\BLOCK{ if professional_summary }
\section{Professional Summary}
  \resumeSubHeadingListStart
    \resumeItemBullet{\VAR{professional_summary}}
  \resumeSubHeadingListEnd
\BLOCK{ endif }

%-----------EXPERIENCE-----------------
\BLOCK{ if experience }
\section{Experience}
  \resumeSubHeadingListStart
    \BLOCK{ for exp in experience }
    \resumeSubheading
      {\VAR{exp.company}}{\VAR{exp.dates}}
      {\VAR{exp.title}}{}
      \resumeItemListStart
        \BLOCK{ for point in exp.bullet_points }
        \resumeItemBullet{\VAR{point}}
        \BLOCK{ endfor }
      \resumeItemListEnd
    \BLOCK{ endfor }
  \resumeSubHeadingListEnd
\BLOCK{ endif }

%-----------PROJECTS-----------------
\BLOCK{ if projects }
\section{Projects}
  \resumeSubHeadingListStart
    \BLOCK{ for project in projects }
    \resumeItem{\VAR{project.name}}{\BLOCK{ if project.link }\href{\VAR{project.link}}{Link}\BLOCK{ endif }}
    \BLOCK{ if project.description }
    \resumeItemBullet{\VAR{project.description}}
    \BLOCK{ endif }
    \BLOCK{ if project.technologies }
    \resumeItemBullet{Technologies: \VAR{project.technologies}}
    \BLOCK{ endif }
    \BLOCK{ endfor }
  \resumeSubHeadingListEnd
\BLOCK{ endif }

%-----------SKILLS-----------------
\BLOCK{ if skills }
\section{Skills}
 \resumeSubHeadingListStart
    \resumeItemBullet{\VAR{skills | join(', ')}}
 \resumeSubHeadingListEnd
\BLOCK{ endif }

%-----------ACHIEVEMENTS-----------------
\BLOCK{ if achievements }
\section{Achievements}
 \resumeSubHeadingListStart
    \BLOCK{ for achievement in achievements }
    \resumeItemBullet{\VAR{achievement}}
    \BLOCK{ endfor }
 \resumeSubHeadingListEnd
\BLOCK{ endif }

\end{document}
